# ========================================
# 商圈查找工具 - 环境变量配置文件
# ========================================
# 使用方法：复制此文件为 .env 并填写相应的值
# cp .env.example .env

# ========================================
# 高德地图 API 配置（必需）
# ========================================
# 高德开放平台：https://console.amap.com/

# Web服务 API Key（用于POI搜索等后端API调用）
# 创建方式：应用管理 → 我的应用 → 添加Key → 服务平台选择"Web服务"
AMAP_API_KEY=your_web_service_api_key_here

# Web端(JS API) Key（用于前端地图显示）
# 创建方式：应用管理 → 我的应用 → 添加Key → 服务平台选择"Web端(JS API)"
# 注意：这是与 AMAP_API_KEY 不同的Key类型！
AMAP_JS_KEY=your_js_api_key_here

# JS API 安全密钥（高德地图JS API 2.0必须配置，否则地图无法显示）
# 获取方式：创建Web端(JS API)类型的Key后，在Key详情中可以看到"安全密钥"
AMAP_SECURITY_CODE=your_security_code_here

# ========================================
# Web服务配置（可选，有默认值）
# ========================================

# Flask Session 密钥（生产环境务必修改为随机字符串）
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# Web登录用户名（默认：admin）
WEB_USERNAME=admin

# Web登录密码（生产环境务必修改为强密码）
WEB_PASSWORD=admin123

# Web服务端口（默认：5002）
PORT=5002

# Flask调试模式（生产环境设为False）
FLASK_DEBUG=False

# ========================================
# 搜索参数配置（可选，有默认值）
# ========================================

# 默认距离阈值，单位：米（默认：200）
# 门店之间的最大距离，超过此距离不认为是同一商圈
DEFAULT_DISTANCE_THRESHOLD=200

# 门店去重距离阈值，单位：米（默认：200）
# 搜索品牌门店时，距离小于此值的门店认为是同一家店，会进行去重
DEDUPLICATION_DISTANCE=200

# ========================================
# 生产环境配置（使用gunicorn时）
# ========================================

# gunicorn工作进程数（建议：CPU核心数 * 2 + 1）
WORKERS=4
